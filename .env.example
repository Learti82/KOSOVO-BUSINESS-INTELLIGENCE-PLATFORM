# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost/kosovaintel

# Auth
JWT_SECRET=change_this_to_a_random_64_character_string_for_production_use_only
JWT_EXPIRY=7d

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=KosovaIntel <reports@kosovaintel.com>

# Redis
REDIS_URL=redis://localhost:6379

# Storage
UPLOADS_PATH=./uploads
REPORTS_PATH=./uploads/reports

# Business
COMPANY_NAME=KosovaIntel
COMPANY_EMAIL=info@kosovaintel.com
BASE_URL=http://localhost:5173
