# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost/kosovaintel

# Auth
JWT_SECRET=change_this_to_a_random_64_character_string_for_production_use_only
JWT_EXPIRY=7d

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email — Resend (preferred for real delivery)
RESEND_API_KEY=
# Or SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=KosovaIntel <reports@kosovaintel.com>

# Demo behavior — set to 'false' to require manual analyst review flow
DEMO_MODE=true
# Disable nightly cron (set to 'true' to disable)
DISABLE_CRON=false
# Public API v1 key for institutional clients
PUBLIC_API_KEY=change-this-to-a-long-random-string

# Redis
REDIS_URL=redis://localhost:6379

# Storage
UPLOADS_PATH=./uploads
REPORTS_PATH=./uploads/reports

# Business
COMPANY_NAME=KosovaIntel
COMPANY_EMAIL=info@kosovaintel.com
BASE_URL=http://localhost:5173
